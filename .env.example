# LLM 配置
LLM_PROVIDER=openai_api_compatible
LLM_MODEL=your-model-name
LLM_API_KEY=your-api-key
LLM_API_BASE=http://localhost:8000/v1
LLM_TEMPERATURE=0

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gaussdb
DB_USER=admin
DB_PASSWORD=

# 知识库配置
KNOWLEDGE_BASE_ID=your-kb-id
KNOWLEDGE_TOP_K=3
KNOWLEDGE_SCORE_THRESHOLD=0.3

# Excel 输出配置
EXCEL_OUTPUT_DIR=./excel_output
EXCEL_FILENAME_PREFIX=测试用例_

# XMind 输出配置
XMIND_OUTPUT_DIR=./xmind_output

# 通知配置
NOTIFICATION_ENABLED=true
